# =============================================================================
# QDataV2 Server — .gitignore
# Django 5 + Python 3.11 + PostgreSQL + Redis
# =============================================================================

# =============================================================================
# 🔐 安全敏感 — 绝对不能提交
# =============================================================================
# 环境变量（含数据库密码、Secret Key、第三方 API 密钥）
.env
.env.*
!.env.example
*.env

# JWT 密钥对
keys/
!keys/.gitkeep
*.pem

# Claude 本地配置（含个人 GitHub PAT、数据库密码等）
.claude/settings.local.json

# =============================================================================
# 🐍 Python
# =============================================================================
__pycache__/
*.py[cod]
*.so
.Python

# 包构建产物
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
develop-eggs/
downloads/
var/
sdist/
wheels/
lib/
lib64/
.installed.cfg

# =============================================================================
# 🌐 Django
# =============================================================================
local_settings.py
staticfiles/
/media/
db.sqlite3
db.sqlite3-journal

# i18n 编译产物（通过 make compilemessages 重新生成）
*.mo

# OpenAPI 导出产物（通过 make schema 重新生成）
.openapi_exports/
openapi.yaml

# =============================================================================
# 🧪 测试 & 代码覆盖率
# =============================================================================
.pytest_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml

# =============================================================================
# 🔍 类型检查 & Lint 缓存
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pylint.d/

# =============================================================================
# 📦 虚拟环境
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
# 🛠 IDE & 编辑器
# =============================================================================

# VS Code —— 保留项目级配置，忽略个人本地覆盖
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# Cursor —— environment.json 含机器特定路径（OS、shell、工作目录等）
# 如需提交 Cursor AI 规则，放在 .cursor/rules/ 并显式取消忽略：
# !.cursor/rules/
.cursor/environment.json

# JetBrains (PyCharm, IDEA 等)
.idea/
*.iws
*.iml
*.ipr
out/

# Vim/Emacs
*.swp
*.swo
*~
\#*\#
.#*

# =============================================================================
# 📝 日志
# =============================================================================
logs/*.log
logs/*.log.*
*.log

# =============================================================================
# 🗂 系统文件
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# 🔧 其他工具缓存
# =============================================================================
.cache/
*.bak
*.tmp
*.temp

# =============================================================================
# ✅ 下列配置有意提交（团队共享）
# =============================================================================
# .github/                 → CI/CD workflows, Dependabot, GitHub Copilot Agent
# .vscode/settings.json    → 项目级编辑器配置（格式化、lint、测试）
# .vscode/extensions.json  → 推荐插件列表
# .vscode/launch.json      → 调试配置
# .vscode/tasks.json       → 构建 / 测试任务
# .claude/settings.json    → 项目级 Claude 工具权限白名单
# .cursorignore            → 项目级 Cursor 忽略规则
# .editorconfig            → 跨编辑器代码风格统一
# .pylintrc                → 项目级 Pylint 配置

.openapi_exports/
openapi.yaml

/.ai/

*.session.sql
/docs/CHECK/
